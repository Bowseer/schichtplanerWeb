@model IEnumerable<Schicht>
@{ ViewData["Title"] = "Schichten"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h1>Schichten</h1><a asp-action="Create" class="btn btn-primary">Neu</a></div>
<table class="table table-striped table-hover"><thead><tr><th>Datum</th><th>Mitarbeiter</th><th>Standort</th><th>Beginn</th><th>Ende</th><th>Pause</th><th>Stunden</th><th></th></tr></thead><tbody>
@foreach (var item in Model) {
<tr><td>@item.Datum.ToString("dd.MM.yyyy")</td><td>@item.Mitarbeiter?.VollerName</td><td>@item.Standort?.Name</td><td>@item.Beginn</td><td>@item.Ende</td><td>@item.PauseMinuten min</td><td>@item.Stunden</td><td class="text-end"><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Bearbeiten</a> <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Löschen</a></td></tr>
}
</tbody></table>
