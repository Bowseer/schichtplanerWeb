@model Mitarbeiter
@{ ViewData["Title"] = "Mitarbeiter bearbeiten"; }
<h1>Mitarbeiter bearbeiten</h1>
<form asp-action="Edit" method="post">
<input asp-for="Id" type="hidden" />
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="Vorname" class="form-label"></label><input asp-for="Vorname" class="form-control" /><span asp-validation-for="Vorname" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="Nachname" class="form-label"></label><input asp-for="Nachname" class="form-control" /><span asp-validation-for="Nachname" class="text-danger"></span></div></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="StandortId" class="form-label">Standort</label><select asp-for="StandortId" asp-items="ViewBag.StandortId" class="form-select"></select><span asp-validation-for="StandortId" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="EmploymentType" class="form-label"></label><select asp-for="EmploymentType" asp-items="Html.GetEnumSelectList<EmploymentType>()" class="form-select"></select></div></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="MaxStundenProMonat" class="form-label"></label><input asp-for="MaxStundenProMonat" class="form-control" /><span asp-validation-for="MaxStundenProMonat" class="text-danger"></span></div><div class="col-md-3 mb-3 form-check mt-4"><input asp-for="NurSamstag" class="form-check-input" /><label asp-for="NurSamstag" class="form-check-label"></label></div><div class="col-md-3 mb-3 form-check mt-4"><input asp-for="Aktiv" class="form-check-input" /><label asp-for="Aktiv" class="form-check-label"></label></div></div>
<button type="submit" class="btn btn-primary">Speichern</button> <a asp-action="Index" class="btn btn-secondary">Abbrechen</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
