<!DOCTYPE html>
<html lang="de">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>@ViewData["Title"] - Schichtplaner</title>
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
		<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	</head>
	<body>
		<header>
			<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
				<div class="container-fluid">
					<a class="navbar-brand" asp-controller="Monatsplanung" asp-action="Index">Schichtplaner</a>
					<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
						<span class="navbar-toggler-icon"></span>
					</button>
					<div class="collapse navbar-collapse" id="navbarNav">
						<ul class="navbar-nav me-auto">
							<li class="nav-item">
								<a class="nav-link" asp-controller="Monatsplanung" asp-action="Index">Monatsplanung</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" asp-controller="Standorte" asp-action="Index">Standorte</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" asp-controller="Mitarbeiter" asp-action="Index">Mitarbeiter</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" asp-controller="Schichten" asp-action="Index">Schichten</a>
							</li>
							@if (User.IsInRole("Admin"))
							{
							<li class="nav-item">
								<a class="nav-link" asp-controller="Admin" asp-action="Users">Usermanagement</a>
							</li>
							}
						</ul>

						@if (User.Identity?.IsAuthenticated == true)
						{
						<form asp-controller="Account" asp-action="Logout" method="post" class="d-flex">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
						</form>
						}
					</div>
				</div>
			</nav>
		</header>

		<div class="container mt-4">
			@RenderBody()
		</div>

		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
		@await RenderSectionAsync("Scripts", required: false)
	</body>
</html>
