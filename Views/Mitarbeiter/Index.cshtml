@model IEnumerable<Mitarbeiter>
@{
    ViewData["Title"] = "Mitarbeiter";
    var selectedStandortId = Context.Request.Query["standortId"].ToString();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Mitarbeiter</h1>
    <a asp-action="Create" class="btn btn-primary">Neu</a>
</div>

<form method="get" class="row g-3 mb-3">
    <div class="col-md-4">
        <label class="form-label">Standort</label>
        <select name="standortId" asp-items="ViewBag.StandortFilter" class="form-select">
            <option value="">Alle</option>
        </select>
    </div>
    <div class="col-md-2 align-self-end">
        <button type="submit" class="btn btn-primary">Filtern</button>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Standort</th>
            <th>Typ</th>
            <th>Max. h/Monat</th>
            <th>Nur Samstag</th>
            <th>Aktiv</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.VollerName</td>
                <td>@item.Standort?.Name</td>
                <td>@item.EmploymentType</td>
                <td>@item.MaxStundenProMonat</td>
                <td>@(item.NurSamstag ? "Ja" : "Nein")</td>
                <td>@(item.Aktiv ? "Ja" : "Nein")</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Bearbeiten</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">LÃ¶schen</a>
                </td>
            </tr>
        }
    </tbody>
</table>
