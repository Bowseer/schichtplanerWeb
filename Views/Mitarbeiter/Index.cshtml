@model IEnumerable<Mitarbeiter>
@{ ViewData["Title"] = "Mitarbeiter"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h1>Mitarbeiter</h1><a asp-action="Create" class="btn btn-primary">Neu</a></div>
<table class="table table-striped table-hover"><thead><tr><th>Name</th><th>Standort</th><th>Typ</th><th>Max. h/Monat</th><th>Nur Samstag</th><th>Aktiv</th><th></th></tr></thead><tbody>
@foreach (var item in Model) {
<tr><td>@item.VollerName</td><td>@item.Standort?.Name</td><td>@item.EmploymentType</td><td>@item.MaxStundenProMonat</td><td>@(item.NurSamstag ? "Ja" : "Nein")</td><td>@(item.Aktiv ? "Ja" : "Nein")</td><td class="text-end"><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Bearbeiten</a> <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Löschen</a></td></tr>
}
</tbody></table>
