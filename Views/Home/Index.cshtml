@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm"><div class="card-body"><h5 class="card-title">Standorte</h5><p class="display-6">@Model.AnzahlStandorte</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm"><div class="card-body"><h5 class="card-title">Aktive Mitarbeiter</h5><p class="display-6">@Model.AnzahlMitarbeiter</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm"><div class="card-body"><h5 class="card-title">Schichten im Monat</h5><p class="display-6">@Model.AnzahlSchichtenDiesenMonat</p></div></div>
    </div>
</div>

@if (Model.Warnungen.Any())
{
    <div class="alert alert-warning">
        <h5>Warnungen</h5>
        <ul class="mb-0">
            @foreach (var warnung in Model.Warnungen)
            {
                <li>@warnung</li>
            }
        </ul>
    </div>
}
