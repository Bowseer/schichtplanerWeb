@model IEnumerable<Schicht>
@{
    ViewData["Title"] = "Schichten";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Schichten</h1>
</div>

<form method="get" class="row g-3 mb-3">
    <div class="col-md-3">
        <label class="form-label">Mitarbeiter</label>
        <select name="mitarbeiterId" asp-items="ViewBag.MitarbeiterId" class="form-select">
            <option value="">Alle</option>
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Standort</label>
        <select name="standortId" asp-items="ViewBag.StandortId" class="form-select">
            <option value="">Alle</option>
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label">Jahr</label>
        <input type="number" name="jahr" value="@ViewBag.Jahr" class="form-control" />
    </div>

    <div class="col-md-2">
        <label class="form-label">Monat</label>
        <input type="number" name="monat" value="@ViewBag.Monat" min="1" max="12" class="form-control" />
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">Filtern</button>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Datum</th>
            <th>Slot</th>
            <th>Mitarbeiter</th>
            <th>Standort</th>
            <th>Beginn</th>
            <th>Ende</th>
            <th>Stunden</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Datum.ToString("dd.MM.yyyy")</td>
                <td>
                    @(
                        s.Slot == 1 ? "Fr\u00FCh" :
                        s.Slot == 2 ? "Flex" :
                        s.Slot == 3 ? "Sp\u00E4t" : "?"
                    )
                </td>
                <td>@s.Mitarbeiter?.VollerName</td>
                <td>@s.Standort?.Name</td>
                <td>@s.Beginn.ToString(@"hh\:mm")</td>
                <td>@s.Ende.ToString(@"hh\:mm")</td>
                <td>@s.Stunden</td>
            </tr>
        }
    </tbody>
</table>