@model SchichtCreateViewModel
@{ ViewData["Title"] = "Schicht anlegen"; }
<h1>Schicht anlegen</h1>
<form asp-action="Create" method="post">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="MitarbeiterId" class="form-label">Mitarbeiter</label><select asp-for="MitarbeiterId" asp-items="Model.MitarbeiterListe" class="form-select"></select><span asp-validation-for="MitarbeiterId" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="StandortId" class="form-label">Standort</label><select asp-for="StandortId" asp-items="Model.StandortListe" class="form-select"></select><span asp-validation-for="StandortId" class="text-danger"></span></div></div>
<div class="row"><div class="col-md-4 mb-3"><label asp-for="Datum" class="form-label"></label><input asp-for="Datum" class="form-control" /></div><div class="col-md-4 mb-3"><label asp-for="Beginn" class="form-label"></label><input asp-for="Beginn" type="time" class="form-control" /></div><div class="col-md-4 mb-3"><label asp-for="Ende" class="form-label"></label><input asp-for="Ende" type="time" class="form-control" /></div></div>
<div class="mb-3"><label asp-for="PauseMinuten" class="form-label"></label><input asp-for="PauseMinuten" class="form-control" /><span asp-validation-for="PauseMinuten" class="text-danger"></span></div>
<button type="submit" class="btn btn-primary">Speichern</button> <a asp-action="Index" class="btn btn-secondary">Abbrechen</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
