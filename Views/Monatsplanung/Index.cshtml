@model MonatsplanViewModel

<h2>Monatsplanung</h2>

<form method="get">
    <select name="standortId">
        @foreach (var s in Model.Standorte)
        {
            <option value="@s.Id" selected="@(s.Id == Model.StandortId)">
                @s.Name
            </option>
        }
    </select>

    <input type="number" name="jahr" value="@Model.Jahr" />
    <input type="number" name="monat" value="@Model.Monat" min="1" max="12" />

    <button type="submit">Laden</button>
</form>

<div class="layout">

    <div class="sidebar">
        @foreach (var m in Model.Mitarbeiter)
        {
            <div class="mitarbeiter" style="background:@m.Farbe">
                @m.Name<br />
                Rest: @m.Reststunden h
            </div>
        }
    </div>

    <div class="kalender">

        <div class="header">
            <div>Mo</div><div>Di</div><div>Mi</div><div>Do</div><div>Fr</div><div>Sa</div><div>So</div>
        </div>

        @foreach (var w in Model.Wochen)
        {
            <div class="woche">
                @foreach (var t in w.Tage)
                {
                    <div class="tag @(t.IstSonntag ? "sonntag" : "")">
                        <div class="datum">@t.Datum.Day</div>

                        @foreach (var s in t.Slots)
                        {
                            <div class="slot" style="background:@s.Farbe">
                                @s.MitarbeiterName
                            </div>
                        }
                    </div>
                }
            </div>
        }

    </div>

</div>